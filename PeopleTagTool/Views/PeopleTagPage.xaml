<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleTagTool.Views.PeopleTagPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PeopleTagTool.Views"
    xmlns:viewModels="using:PeopleTagTool.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Index" Command="{x:Bind ViewModel.DetectFacesCommand}"/>

            <TextBlock VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"/>            

            <TextBlock Margin="32,0,0,0" VerticalAlignment="Center" Text="Count:"/>
            <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.DetectedFaces.Count, Mode=OneWay}"/>

            <TextBlock Margin="32,0,0,0" VerticalAlignment="Center" Text="Minimum face size:"/>
            <Slider
                Width="200"
                Minimum="0"
                Maximum="400"
                StepFrequency="10"
                Value="{x:Bind ViewModel.MinSize, Mode=TwoWay}"/>
        </StackPanel>

        <GridView 
            x:Name="gridView" 
            Grid.Row="1"
            Margin="0,8,0,0" 
            ItemsSource="{x:Bind ViewModel.DetectedFaces}" 
            SelectionChanged="GridView_SelectionChanged">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:DetectedFaceViewModel">
                    <local:DetectedFaceView DataContext="{x:Bind}"/>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBox
                PlaceholderText="Type to search"
                Text="{x:Bind ViewModel.NameSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                KeyDown="PersonNameTextBox_KeyDown"/>
            <ListView                
                Grid.Row="1" 
                Margin="0,8,0,0"
                ItemsSource="{x:Bind ViewModel.PeopleNames, Mode=OneWay}" 
                SelectionMode="None"
                IsItemClickEnabled="True"
                ItemClick="ListView_ItemClick"/>
        </Grid>
    </Grid>

</UserControl>
